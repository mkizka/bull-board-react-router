{
  "name": "bull-board-react-router",
  "version": "1.1.1",
  "type": "module",
  "description": "A bull-board adapter for React Router v7",
  "repository": {
    "type": "git",
    "url": "https://github.com/mkizka/bull-board-react-router.git"
  },
  "author": "mkizka",
  "license": "MIT",
  "packageManager": "pnpm@11.7.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "format": "prettier --write . && eslint --fix .",
    "lint": "prettier --check . && eslint .",
    "prepare": "husky",
    "release": "np --no-tests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bull-board/api": "^7.0.0",
    "@bull-board/ui": "^7.0.0",
    "ejs": "^6.0.0",
    "mime": "^4.1.0",
    "urlpattern-polyfill": "^10.1.0"
  },
  "devDependencies": {
    "@mkizka/eslint-config": "10.0.0",
    "@tsconfig/node-lts": "24.0.0",
    "@tsconfig/strictest": "2.0.8",
    "@types/ejs": "3.1.5",
    "@types/node": "25.9.3",
    "eslint": "10.5.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "np": "11.2.1",
    "prettier": "3.8.4",
    "prettier-plugin-pkg": "0.22.1",
    "typescript": "6.0.3"
  },
  "lint-staged": {
    "*": [
      "prettier --ignore-unknown --write",
      "eslint --fix"
    ]
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-pkg"
    ]
  }
}
